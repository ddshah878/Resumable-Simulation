RETRY_BASE_DELAY_SEC=2
RETRY_MAX_DELAY_SEC=60
PRIORITY_AGING_RATE=0.1
CIRCUIT_BREAKER_FAILURE_THRESHOLD=5
CIRCUIT_BREAKER_RECOVERY_SEC=30
